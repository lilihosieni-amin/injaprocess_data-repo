# Upload staging buffer — finalized files move out of here (ARD §2.2, FR-U7)
.staging/

# Meeting audio — large binaries kept off the remote; transcripts are the source of record
meetings/audio/*
!meetings/audio/.gitkeep

# Secrets never live in data-repo (ARD §14)
.env
*.env
*.key
*service-account*.json

# Python caches
__pycache__/
*.pyc
